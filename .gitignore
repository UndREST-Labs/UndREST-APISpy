# Results directory
results/
*.sarif

# CodeQL temporary files
.codeql/
*.qls

# CodeQL libraries (downloaded/extracted)
codeql-javascript/
codeql-shared/
codeql/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
ENV/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Azure REST API specs clone (managed by refresh scripts)
azure-rest-api-specs/

# Database directory (created by refresh scripts, not tracked in git)
# Empty directories can't be committed to Git
database/

# API inventory export output (generated by scripts/export/)
inventory/*.json
inventory/*.min.json
inventory/api-index-sharded-*.zip

# APISpy portal sweep output files (local/transient)
apispy-*.csv
apispy-sweep-*.webm
apispy-portal-sweep-browser.gif

# Azure provider operations sweep output files (provider_ops_sweep.py)
azure-provider-operations-*.json
azure-provider-summary-*.json
azure-provider-errors-*.json
azure-top-risky-operations-*.json

# Generated but committed (pipeline-owned): do NOT ignore these paths.
# - extension/data/shards/               (update-shards.yml + scripts/prepare_data.py)
# - extension/data/manifest.json         (generated by scripts/prepare_data.py)
# - extension/data/azure-provider-ops.json (generated by scripts/prepare_provider_ops.py)
# - demos/apispy-*.png                   (update-screenshots.yml + scripts/generate_screenshots.py)
